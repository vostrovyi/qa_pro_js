  "item": [
    {
      "name": "Book ISBN Numbers",
      "item": [
        {
          "name": "Is Valid ISBN13 Number",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "let response = pm.response.text();",
                  "let json = xml2Json(response);",
                  "",
                  "let result = json[\"soap:Envelope\"][\"soap:Body\"]",
                  "[\"m:IsValidISBN13Response\"][\"m:IsValidISBN13Result\"];",
                  "",
                  "",
                  "pm.test(\"Status code is 200\", () => {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test(\"Response is not empty\", () => {",
                  "    pm.expect(response).to.not.be.empty;",
                  "});",
                  "",
                  "pm.test(\"Contains SOAP Envelope\", () => {",
                  "    pm.expect(response).to.include(\"<soap:Envelope\");",
                  "});",
                  "",
                  "pm.test(\"Contains SOAP Body\", () => {",
                  "    pm.expect(response).to.include(\"<soap:Body>\");",
                  "});",
                  "",
                  "pm.test(\"Contains ISBN13 response node\", () => {",
                  "    pm.expect(response).to.include(\"IsValidISBN13Response\");",
                  "});",
                  "",
                  "pm.test(\"Result exists\", () => {",
                  "    pm.expect(result).to.exist;",
                  "});",
                  "",
                  "pm.test(\"Result is true or false\", () => {",
                  "    pm.expect([\"true\", \"false\"]).to.include(result);",
                  "});",
                  "",
                  "pm.test(\"ISBN13 is valid\", () => {",
                  "    pm.expect(result).to.eql(\"true\");",
                  "});",
                  "",
                  "pm.test(\"Content-Type is XML\", () => {",
                  "    pm.expect(pm.response.headers.get(\"Content-Type\")).to.include(\"xml\");",
                  "});",
                  "",
                  "pm.test(\"Response time < 2000ms\", () => {",
                  "    pm.expect(pm.response.responseTime).to.be.below(2000);",
                  "});",
                  "",
                  "pm.test(\"Envelope namespace is correct\", () => {",
                  "    pm.expect(response).to.include('xmlns:soap=\"http://schemas.xmlsoap.org/soap/envelope/\"');",
                  "});",
                  "",
                  "pm.test(\"ISBN namespace is correct\", () => {",
                  "    pm.expect(response).to.include('xmlns:m=\"http://webservices.daehosting.com/ISBN\"');",
                  "});"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "text/xml; charset=utf-8",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "<?xml version=\"1.0\" encoding=\"utf-8\"?>\n<soap:Envelope xmlns:soap=\"http://schemas.xmlsoap.org/soap/envelope/\">\n  <soap:Body>\n    <IsValidISBN13 xmlns=\"http://webservices.daehosting.com/ISBN\">\n      <sISBN>978-1-4612-9090-2</sISBN>\n    </IsValidISBN13>\n  </soap:Body>\n</soap:Envelope>"
            },
            "url": {
              "raw": "http://webservices.daehosting.com/services/isbnservice.wso",
              "protocol": "http",
              "host": [
                "webservices",
                "daehosting",
                "com"
              ],
              "path": [
                "services",
                "isbnservice.wso"
              ]
            },
            "description": "The test is done by calculation on the first 12 digits and compare the result with the checksum number at the end. You have to pass a 13 digits number."
          },
          "response": []
        },
